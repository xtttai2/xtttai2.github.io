---
import BaseLayout from '../layouts/BaseLayout.astro';
import { friendLinks } from '../config/friends';
import { siteConfig } from '../config/site';

const socialIcons = {
  GitHub: `<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 2C6.48 2 2 6.58 2 12.22c0 4.5 2.87 8.32 6.84 9.66.5.1.68-.22.68-.49 0-.24-.01-1.04-.01-1.89-2.78.62-3.37-1.21-3.37-1.21-.46-1.18-1.11-1.5-1.11-1.5-.91-.64.07-.63.07-.63 1 .08 1.53 1.05 1.53 1.05.9 1.56 2.35 1.11 2.92.85.09-.67.35-1.11.63-1.37-2.22-.26-4.55-1.14-4.55-5.09 0-1.13.39-2.05 1.03-2.78-.1-.26-.45-1.31.1-2.73 0 0 .84-.28 2.75 1.06A9.3 9.3 0 0 1 12 6.84c.85 0 1.71.12 2.51.35 1.91-1.34 2.75-1.06 2.75-1.06.55 1.42.2 2.47.1 2.73.64.73 1.03 1.65 1.03 2.78 0 3.96-2.33 4.82-4.56 5.08.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.8 0 .27.18.59.69.49A10.23 10.23 0 0 0 22 12.22C22 6.58 17.52 2 12 2Z"/></svg>`
};
---

<BaseLayout title="关于" description={`关于 ${siteConfig.author}。`}>
  <section class="about-page">
    <article class="panel about-card">
      <img class="about-portrait" src="/images/youyugu.png" alt={`${siteConfig.author} avatar`} />
      <h1 class="about-name">{siteConfig.author}</h1>
      <div class="about-icon-links" aria-label="社交链接">
        {siteConfig.socialLinks.map((link) => (
          <a
            class="about-icon-link"
            href={link.href}
            target={link.href.startsWith('http') ? '_blank' : undefined}
            rel="noreferrer"
            aria-label={link.label}
            title={link.label}
          >
            {
              link.label === 'Luogu' ? (
                <img class="about-icon-image" src="/icons/luogu.svg" alt="" aria-hidden="true" />
              ) : (
                <Fragment set:html={socialIcons[link.label as keyof typeof socialIcons]} />
              )
            }
          </a>
        ))}
      </div>
      <section class="about-friends" aria-labelledby="friend-links-title">
        <h2 id="friend-links-title" class="about-friends-title">友链</h2>
        <div class="friend-links-grid">
          {friendLinks.map((friend) => (
            <a
              class="friend-link-card"
              href={friend.href}
              target={friend.href.startsWith('http') ? '_blank' : undefined}
              rel="noreferrer"
            >
              <img class="friend-link-avatar" src={friend.avatar} alt={`${friend.name} avatar`} />
              <span class="friend-link-name">{friend.name}</span>
            </a>
          ))}
        </div>
      </section>
    </article>
  </section>
</BaseLayout>
