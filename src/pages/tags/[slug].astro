---
import { getTagsWithPosts } from '../../lib/posts';

export async function getStaticPaths() {
  const tags = await getTagsWithPosts();

  return tags.map((tag) => ({
    params: { slug: tag.slug },
    props: { tagName: tag.name }
  }));
}

const { tagName } = Astro.props;
const target = `/search?q=${encodeURIComponent(`#${tagName} `)}`;
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <link rel="canonical" href={target} />
    <title>Redirecting...</title>
  </head>
  <body>
    <script is:inline define:vars={{ target }}>window.location.replace(target);</script>
  </body>
</html>
