---
import 'katex/dist/katex.min.css';
import '../styles/global.css';
import { siteConfig } from '../config/site';

interface Props {
  title?: string;
  description?: string;
}

const { title = siteConfig.title, description = siteConfig.description } = Astro.props;
const pageTitle = title === siteConfig.title ? title : `${title} · ${siteConfig.title}`;
const pathname = Astro.url.pathname;
const collapsibleHeader = pathname.startsWith('/posts/');
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f7f4eb" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header-bar" data-site-header>
      <div class="site-header">
        <a class="site-brand" href="/">xtttai2's blog</a>
        <nav class="site-nav" aria-label="主导航">
          <a class={pathname === '/' ? 'is-active' : ''} href="/">首页</a>
          <a class={pathname.startsWith('/categories') ? 'is-active' : ''} href="/categories">类别</a>
          <a class={pathname.startsWith('/search') ? 'is-active' : ''} href="/search">搜索</a>
          <a class={pathname.startsWith('/about') ? 'is-active' : ''} href="/about">关于</a>
        </nav>
      </div>
    </header>
    <div class="page-shell">
      <main class="page-main">
        <slot />
      </main>
      <footer class="site-footer">
        <p>Markdown / KaTeX / Astro 静态生成。</p>
        <p>
          评论由 Giscus 提供，部署目标为 <code>xtttai2.github.io</code>。
        </p>
      </footer>
    </div>

    {
      collapsibleHeader && (
        <script is:inline>
          const header = document.querySelector('[data-site-header]');
          let lastScrollY = window.scrollY;

          const syncHeaderVisibility = () => {
            if (!header) return;

            const currentScrollY = window.scrollY;
            const shouldHide = currentScrollY > 12 && currentScrollY > lastScrollY;
            header.classList.toggle('is-hidden', shouldHide);
            lastScrollY = currentScrollY;
          };

          window.addEventListener('scroll', syncHeaderVisibility, { passive: true });
        </script>
      )
    }
  </body>
</html>
