---
import type { TagArchive } from '../lib/posts';

interface Props {
  tags: TagArchive[];
  currentTag?: string;
  variant?: 'list' | 'inline';
}

const { tags, currentTag, variant = 'list' } = Astro.props;
---

{
  variant === 'inline' ? (
    <div class="tag-cloud">
      {tags.map((tag) => (
        <a
          class:list={['category-label', 'tag-cloud-link', currentTag === tag.name && 'is-current']}
          href={`/tags/${tag.slug}/`}
        >
          {tag.name}
        </a>
      ))}
    </div>
  ) : (
    <div class="category-list">
      {tags.map((tag) => (
        <a
          class:list={['category-link', currentTag === tag.name && 'is-current']}
          href={`/tags/${tag.slug}/`}
        >
          <span class="category-label category-link-name">{tag.name}</span>
          <span>{tag.count}</span>
        </a>
      ))}
    </div>
  )
}
