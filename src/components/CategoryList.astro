---
import type { CategoryArchive } from '../lib/posts';

interface Props {
  categories: CategoryArchive[];
  currentCategory?: string;
}

const { categories, currentCategory } = Astro.props;
---

<div class="category-list">
  {categories.map((category) => (
    <a
      class:list={['category-link', currentCategory === category.name && 'is-current']}
      href={`/categories/${category.slug}/`}
    >
      <span class="category-label category-link-name">{category.name}</span>
      <span>{category.count}</span>
    </a>
  ))}
</div>
